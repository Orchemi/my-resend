# MyResend environment template.
#
# Copy this file to `.env.local` and fill in the values.
# Never commit `.env.local`.
#
# Key reference (also documented in CLAUDE.md § Environment Configuration):
#   - REQUIRED keys must be set for the app to boot.
#   - CONDITIONAL keys are required only when the relevant feature is active.
#   - OPTIONAL keys gate an integration that is off when the key is empty.

# ────────────────────────────────────────────────────────────────────────────
# Database (REQUIRED)
# ────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string. The app uses raw `pg` and parses this directly.
# See SETUP.md § Environment Configuration for the exact format.
#
# Quick local setup (requires Docker):
#   docker compose up -d postgres
#   DATABASE_URL=postgresql://my_resend:my_resend_dev@localhost:5432/my_resend
#
# Missing or empty DATABASE_URL now throws on first DB use with a clear
# error pointing back to this file — the app no longer falls through to
# libpq defaults.
DATABASE_URL=

# ────────────────────────────────────────────────────────────────────────────
# AWS SES (REQUIRED)
# ────────────────────────────────────────────────────────────────────────────

# SES region. Route53 client also uses this if DNS_PROVIDER=route53.
AWS_REGION=us-east-1

# IAM user with the SES v2 policy from SETUP.md (and the Route53 policy
# when DNS_PROVIDER=route53). Same credentials for both.
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=

# ────────────────────────────────────────────────────────────────────────────
# Authentication (REQUIRED)
# ────────────────────────────────────────────────────────────────────────────

# JWT signing secret. Generate with: openssl rand -base64 64
NEXTAUTH_SECRET=

# Public origin used in some auth flows. Leave empty for local dev.
# Example: https://your-domain.example.com
NEXTAUTH_URL=

# ────────────────────────────────────────────────────────────────────────────
# Admin user seed (REQUIRED)
# ────────────────────────────────────────────────────────────────────────────

# Run `curl -X POST http://localhost:3000/api/setup` once after boot to
# create the admin user from these values. Re-running is idempotent.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# ────────────────────────────────────────────────────────────────────────────
# DNS provider
# ────────────────────────────────────────────────────────────────────────────

# Active provider: "route53" (default) or "digitalocean".
DNS_PROVIDER=route53

# DigitalOcean API token. CONDITIONAL — required when DNS_PROVIDER=digitalocean.
# Create at: https://cloud.digitalocean.com/account/api/tokens
DO_API_TOKEN=dop_v1_...

# Route53 hosted zone ID. OPTIONAL — leave empty to auto-discover via
# ListHostedZonesByName (walks up to parent zones).
AWS_HOSTED_ZONE_ID=

# ────────────────────────────────────────────────────────────────────────────
# Email defaults (OPTIONAL)
# ────────────────────────────────────────────────────────────────────────────

# Fallback "From" address for system-generated mail (e.g. waitlist notifications).
# If empty, the app falls back to a built-in default.
FROM_EMAIL=

# ────────────────────────────────────────────────────────────────────────────
# Cron endpoints (OPTIONAL)
# ────────────────────────────────────────────────────────────────────────────

# Shared secret expected in the X-CRON-SECRET header by /api/cron/*.
# Leave empty to disable cron endpoints.
CRON_SECRET=

# ────────────────────────────────────────────────────────────────────────────
# External stats integration (OPTIONAL)
# ────────────────────────────────────────────────────────────────────────────

# Token clients must present to call /api/stats.
STATS_API_KEY=

# Outbound push target for periodic stats reports (cron job).
STATS_APP_SLUG=
STATS_DASHBOARD_URL=
STATS_PUSH_SECRET=

# ────────────────────────────────────────────────────────────────────────────
# Umami analytics integration (OPTIONAL)
# ────────────────────────────────────────────────────────────────────────────

# When all four are set, /api/stats pulls page-view metrics from Umami.
UMAMI_API_URL=
UMAMI_USERNAME=
UMAMI_PASSWORD=
UMAMI_WEBSITE_ID=

# ────────────────────────────────────────────────────────────────────────────
# Stripe integration (OPTIONAL)
# ────────────────────────────────────────────────────────────────────────────

# Secret key for the Stripe-driven stats path. Leave empty if unused.
STRIPE_SECRET_KEY=
